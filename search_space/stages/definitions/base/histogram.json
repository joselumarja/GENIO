{
  "id": "histogram",
  "name": "Histogram",
  "category": "statistics",
  "description": "Compute image histogram.",
  "parameters": [
    {
      "name": "channel",
      "token": "@channel",
      "type": "integer",
      "required": true,
      "description": "Channel index."
    },
    {
      "name": "mask",
      "token": "@mask",
      "type": "image",
      "required": true,
      "description": "Mask image."
    },
    {
      "name": "bins",
      "token": "@bins",
      "type": "integer",
      "required": true,
      "description": "Number of histogram bins."
    },
    {
      "name": "ranges",
      "token": "@ranges",
      "type": "array",
      "required": true,
      "description": "Histogram value ranges."
    }
  ],
  "interface": {
    "inputs": [
      {
        "format": "image"
      }
    ],
    "outputs": [
      {
        "format": "array"
      }
    ],
    "compatibility": "An output can feed another stage input when format, and any declared dtype/channels constraints, are compatible."
  },
  "implementations": {
    "hls": {
      "vitis_vision": "implementations/hls/vitis_vision/histogram.json"
    },
    "functional": {
      "opencv": "implementations/functional/opencv/histogram.json"
    }
  }
}
