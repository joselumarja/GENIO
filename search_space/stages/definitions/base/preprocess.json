{
  "id": "preprocess",
  "name": "DNN Preprocess",
  "category": "dnn",
  "description": "Preprocess image data for DNN inference.",
  "parameters": [
    {
      "name": "out_rows",
      "token": "@OUT_ROWS",
      "type": "integer",
      "required": true,
      "description": "Output image height."
    },
    {
      "name": "out_cols",
      "token": "@OUT_COLS",
      "type": "integer",
      "required": true,
      "description": "Output image width."
    },
    {
      "name": "interpolation",
      "token": "@INTERPOLATION",
      "type": "enum",
      "required": true,
      "description": "Interpolation policy."
    }
  ],
  "interface": {
    "inputs": [
      {
        "format": "image"
      }
    ],
    "outputs": [
      {
        "format": "array"
      }
    ],
    "compatibility": "An output can feed another stage input when format, and any declared dtype/channels constraints, are compatible."
  },
  "implementations": {
    "hls": {
      "vitis_vision": "implementations/hls/vitis_vision/preprocess.json"
    },
    "functional": {
      "opencv": "implementations/functional/opencv/preprocess.json"
    }
  }
}
