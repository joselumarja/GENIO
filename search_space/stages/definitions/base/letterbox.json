{
  "id": "letterbox",
  "name": "DNN Letterbox",
  "category": "dnn",
  "description": "Resize and pad image preserving aspect ratio.",
  "parameters": [
    {
      "name": "out_rows",
      "token": "@OUT_ROWS",
      "type": "integer",
      "required": true,
      "description": "Output image height."
    },
    {
      "name": "out_cols",
      "token": "@OUT_COLS",
      "type": "integer",
      "required": true,
      "description": "Output image width."
    },
    {
      "name": "interpolation",
      "token": "@INTERPOLATION",
      "type": "enum",
      "required": true,
      "description": "Interpolation policy."
    },
    {
      "name": "border_type",
      "token": "@BORDER_TYPE",
      "type": "enum",
      "required": true,
      "description": "Border handling policy."
    },
    {
      "name": "top",
      "token": "@top",
      "type": "integer",
      "required": true,
      "description": "Top border size."
    },
    {
      "name": "bottom",
      "token": "@bottom",
      "type": "integer",
      "required": true,
      "description": "Bottom border size."
    },
    {
      "name": "left",
      "token": "@left",
      "type": "integer",
      "required": true,
      "description": "Left border size."
    },
    {
      "name": "right",
      "token": "@right",
      "type": "integer",
      "required": true,
      "description": "Right border size."
    }
  ],
  "interface": {
    "inputs": [
      {
        "format": "image"
      }
    ],
    "outputs": [
      {
        "format": "image"
      }
    ],
    "compatibility": "An output can feed another stage input when format, and any declared dtype/channels constraints, are compatible."
  },
  "implementations": {
    "hls": {
      "vitis_vision": "implementations/hls/vitis_vision/letterbox.json"
    },
    "functional": {
      "opencv": "implementations/functional/opencv/letterbox.json"
    }
  }
}
