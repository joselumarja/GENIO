  },
  "implementations": {
    "hls": {
      "vitis_vision": "implementations/hls/vitis_vision/hog_descriptor.json"
    },
    "functional": {
      "scikit_image": "implementations/functional/scikit_image/hog_descriptor.json"
    }
  }
